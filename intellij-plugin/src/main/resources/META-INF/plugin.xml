<idea-plugin>
    <id>com.autoerd.plugin</id>
    <name>AutoERD</name>
    <version>1.0.0</version>
    <vendor url="https://github.com/autoerd">AutoERD</vendor>
    <description><![CDATA[
        AI 기반 DB 모델링 및 ERD 자동 생성 도구.<br>
        요구사항 텍스트를 입력하면 엔티티, 관계, DDL을 자동으로 추출합니다.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!-- 우클릭 컨텍스트 메뉴 액션 -->
    <actions>
        <group id="AutoErdActions" text="AutoERD" popup="true">
            <!-- 프로젝트 탐색기 우클릭 메뉴 -->
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <!-- 에디터 우클릭 메뉴 -->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </group>

        <action id="com.autoerd.plugin.actions.AnalyzeEntityAction"
                class="com.autoerd.plugin.actions.AnalyzeEntityAction"
                text="AutoERD로 분석"
                description="선택한 Java/@Entity 파일 또는 폴더를 파싱해서 AutoERD ERD 생성">
            <add-to-group group-id="AutoErdActions" anchor="first"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window (우측 패널) -->
        <toolWindow
            id="AutoERD"
            anchor="right"
            secondary="false"
            factoryClass="com.autoerd.plugin.AutoErdWindowFactory"
            icon="AllIcons.Nodes.DataSchema"/>

        <!-- 설정 페이지: Settings > Tools > AutoERD -->
        <applicationConfigurable
            parentId="tools"
            id="com.autoerd.plugin.configurable"
            displayName="AutoERD"
            instance="com.autoerd.plugin.AutoErdConfigurable"/>

        <!-- 설정 저장 서비스 -->
        <applicationService
            serviceImplementation="com.autoerd.plugin.AutoErdSettings"/>
    </extensions>
</idea-plugin>
